# ------------------------------------------------------------
# Unreal Engine - C++ Project (No Git LFS)
# ------------------------------------------------------------

# IDE Folders
.vscode/
.idea/
.vs/

# Compiled Object Files
*.slo
*.lo
*.o
*.obj

# Precompiled Headers
*.gch
*.pch

# Compiled Dynamic Libraries
*.so
*.dylib
*.dll

# Compiled Static Libraries
*.lai
*.la
*.a
*.lib

# Executables
*.exe
*.out
*.app
*.ipa

# Visual Studio / Xcode project files (auto-generated by Unreal)
*.xcodeproj
*.xcworkspace
*.sln
*.code-workspace
*.suo
*.opensdf
*.sdf
*.VC.db
*.VC.opendb
.vsconfig

# Precompiled Assets (raw source art)
SourceArt/**/*.png
SourceArt/**/*.tga

# Build Products
Binaries/
Build/

# Plugins
Plugins/**/Binaries/
Plugins/**/Intermediate/

# Ignore everything in Content/
Content/*

# Except Blueprints folder (unignore it and its contents)
!Content/Blueprints/
!Content/Blueprints/**

# Explicitly ignore the Assets folder
Content/Assets/

# Explicitly include Blueprints/
!Content/Blueprints/**

# Intermediate and Derived Data
Intermediate/
DerivedDataCache/

# Saved (auto-generated, per-user)
Saved/

# Engine built map data
*_BuiltData.uasset

# Whitelist PakBlacklist files
!Build/*/
Build/*/**
!Build/*/PakBlacklist*.txt
!Build/**/*.ico

# Log/Temporary/User Files
*.log
*.tlog
*.tmp
*.cache
*.bak
*.pid
*.old
*.orig

# Compiled Source
*.pdb

# macOS Finder files
.DS_Store

# Windows Explorer thumbnails
Thumbs.db
